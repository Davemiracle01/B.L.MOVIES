{
  "version": 2,
  "builds": [
    { "src": "api/movies.js", "use": "@vercel/node" },
    { "src": "index.html",    "use": "@vercel/static" },
    { "src": "public/**",     "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/movies", "dest": "/api/movies.js" },
    { "src": "/videos/(.*)", "dest": "/public/videos/$1" },
    { "src": "/(.*)", "dest": "/index.html" }
  ],
  "headers": [
    {
      "source": "/videos/(.*)",
      "headers": [
        { "key": "Accept-Ranges", "value": "bytes" },
        { "key": "Cache-Control", "value": "public, max-age=86400" }
      ]
    }
  ]
}
